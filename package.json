{
    "name": "tarkov.dev",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "imports": {
        "#src/*": "./src/*",
        "#scripts/*": "./scripts/*",
        "#public/*": "./public/*"
    },
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "analyze": "source-map-explorer 'build/static/js/*.js'",
        "prestart": "pnpm run prebuild",
        "start": "rsbuild start --open",
        "build": "rsbuild build",
        "test": "rstest",
        "prettier": "prettier --write \"src/**/*.{js,jsx,mjs,ts,tsx,json,css,scss,md}\"",
        "prebuild": "node scripts/update-props.mjs && node scripts/get-supported-languages.mjs && node scripts/get-contributors.mjs && node scripts/build-sitemap.mjs && node scripts/generate-thumbnails.mjs",
        "postbuild": "node scripts/build-redirects.mjs && node scripts/critical.mjs",
        "stage": "pnpm dlx rimraf build && pnpm run build && pnpm run preview",
        "preview": "pnpm dlx serve build -l 3001 -s",
        "critical": "node scripts/critical.mjs",
        "lint": "eslint src",
        "prepare": "husky"
    },
    "devDependencies": {
        "@babel/plugin-transform-private-property-in-object": "^7.28.6",
        "@eslint-react/eslint-plugin": "^5.7.2",
        "@eslint/compat": "^2.0.5",
        "@eslint/js": "^10.0.1",
        "@rsbuild/core": "^1.7.5",
        "@rsbuild/plugin-react": "^1.4.6",
        "@rsbuild/plugin-svgr": "^1.3.1",
        "@rstest/core": "^0.9.7",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/react-table": "^7.7.20",
        "confusing-browser-globals": "^1.0.11",
        "critical": "^8.0.0",
        "dotenv": "^17.4.2",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react-hooks": "^7.0.1",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.3",
        "sharp": "^0.34.5",
        "source-map-explorer": "^2.5.3",
        "stylelint": "^17.8.0",
        "stylelint-config-standard": "^40.0.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.59.2"
    },
    "dependencies": {
        "@emotion/styled": "^11.14.1",
        "@marsidev/react-turnstile": "^1.5.3",
        "@mdi/js": "^7.4.47",
        "@mdi/react": "^1.6.1",
        "@mui/material": "^9.0.0",
        "@mui/x-tree-view": "^9.4.0",
        "@reduxjs/toolkit": "^2.11.0",
        "@tanstack/react-query": "^5.99.0",
        "clsx": "^2.1.1",
        "dayjs": "^1.11.20",
        "fast-deep-equal": "^3.1.3",
        "framer-motion": "^12.38.0",
        "fuse.js": "^7.3.0",
        "i18next": "^23.16.8",
        "i18next-browser-languagedetector": "^8.2.1",
        "i18next-http-backend": "^3.0.5",
        "jsonpath-plus": "^10.4.0",
        "leaflet": "^1.9.4",
        "leaflet-fullscreen": "^1.0.2",
        "lodash.debounce": "^4.0.8",
        "lz-string": "^1.5.0",
        "react": "^18.3.1",
        "react-cookie-consent": "^10.0.1",
        "react-countdown": "^2.3.6",
        "react-dom": "^18.3.1",
        "react-error-boundary": "^6.1.1",
        "react-helmet": "^6.1.0",
        "react-hotkeys-hook": "^5.2.4",
        "react-i18next": "^15.4.1",
        "react-intersection-observer": "^10.0.3",
        "react-redux": "^9.2.0",
        "react-router-dom": "^6.30.3",
        "react-router-hash-link": "^2.4.3",
        "react-select": "^5.10.2",
        "react-simple-image-viewer": "1.2.2",
        "react-spinners": "^0.17.0",
        "react-syntax-highlighter": "^16.1.1",
        "react-table": "^7.8.0",
        "react-zoom-pan-pinch": "^4.0.3",
        "resize-observer-polyfill": "^1.5.1",
        "victory": "^37.3.6"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "lint-staged": {
        "*.css": [
            "stylelint --fix",
            "prettier --write --ignore-unknown"
        ],
        "*.{js,jsx,mjs,ts,tsx}": [
            "eslint --fix",
            "prettier --write --ignore-unknown"
        ]
    },
    "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
